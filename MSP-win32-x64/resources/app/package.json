{
  "name": "msp-local-2010",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "start-server": "node app.js --server",
    "start:debug": "electron . --debug",
    "dist": "electron-builder --win",
    "dist:portable": "electron-builder --win portable",
    "dist:folder": "electron-builder --win dir",
    "make-launchers": "powershell -ExecutionPolicy Bypass -File ./tools/make-launchers.ps1",
    "make-slim-client": "powershell -ExecutionPolicy Bypass -File ./tools/make-slim-client.ps1",
    "upload-r2-assets": "node ./tools/upload-r2-assets.js"
  },
  "build": {
    "appId": "com.oxvkarr.msp2010",
    "productName": "MSP 2010",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!dist/**",
      "!node_modules/.cache/**",
      "!msp-db.json",
      "!.env"
    ],
    "asar": true,
    "asarUnpack": [
      "pepflashplayer.dll"
    ],
    "win": {
      "target": [
        "portable",
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "electron": "^11.5.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1045.0",
    "amfjs": "^1.3.1",
    "dotenv": "^17.4.2",
    "express": "^4.22.2",
    "mime-types": "^3.0.2",
    "mongodb": "^4.17.2",
    "xml2js": "^0.6.2"
  }
}
